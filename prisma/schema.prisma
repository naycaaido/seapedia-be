datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

// =========================
// ENUMS
// =========================

enum RoleName {
  Admin
  Seller
  Buyer
  Driver
}

enum WalletTransactionType {
  TOP_UP
  PAYMENT
  REFUND
  ADJUSTMENT
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum DeliveryMethod {
  INSTANT
  NEXT_DAY
  REGULAR
}

enum OrderStatus {
  SEDANG_DIKEMAS
  MENUNGGU_PENGIRIM
  SEDANG_DIKIRIM
  PESANAN_SELESAI
  DIKEMBALIKAN
}

enum DeliveryJobStatus {
  AVAILABLE
  TAKEN
  COMPLETED
  CANCELLED
  RETURNED
}

enum RefundStatus {
  PENDING
  PROCESSED
  FAILED
}

// =========================
// AUTH & ROLE
// =========================

model Role {
  id        Int        @id @default(autoincrement())
  name      RoleName   @unique
  userRoles UserRole[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("roles")
}

model User {
  id           Int     @id @default(autoincrement())
  username     String  @unique
  email        String  @unique
  passwordHash String  @map("password_hash")
  fullName     String  @map("full_name")
  phone        String?

  userRoles UserRole[]

  store             Store?
  wallet            Wallet?
  addresses         Address[]
  cart              Cart?
  orders            Order[]
  reviews           ApplicationReview[]
  statusChanges     OrderStatusHistory[]
  deliveryJobs      DeliveryJob[]
  systemTimeUpdates SystemSetting[]
  refunds           Refund[]

  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  DriverEarning DriverEarning[]

  @@map("users")
}

model UserRole {
  id     Int  @id @default(autoincrement())
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @map("user_id")
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId Int  @map("role_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, roleId])
  @@map("user_roles")
}

// =========================
// PUBLIC REVIEW
// =========================

model ApplicationReview {
  id           Int    @id @default(autoincrement())
  reviewerName String @map("reviewer_name")
  rating       Int
  comment      String

  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId Int?  @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("application_reviews")
}

// =========================
// SELLER, STORE, PRODUCT
// =========================

model Store {
  id           Int  @id @default(autoincrement())
  sellerUser   User @relation(fields: [sellerUserId], references: [id], onDelete: Cascade)
  sellerUserId Int  @unique @map("seller_user_id")

  name        String  @unique
  description String?
  address     String?

  products      Product[]
  carts         Cart[]
  orders        Order[]
  sellerIncomes SellerIncome[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("stores")
}

model Product {
  id      Int   @id @default(autoincrement())
  store   Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId Int   @map("store_id")

  name        String
  description String
  price       Decimal @db.Decimal(12, 2)
  stock       Int     @default(0)
  imageUrl    String? @map("image_url")
  imagePath   String? @map("image_path")

  // Soft delete rule:
  // deletedAt = null      => product is visible/available
  // deletedAt != null     => product is deleted and hidden from public catalog
  deletedAt DateTime? @map("deleted_at")

  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([storeId])
  @@index([deletedAt])
  @@map("products")
}

// =========================
// BUYER ADDRESS & WALLET
// =========================

model Address {
  id Int @id @default(autoincrement())

  buyer   User @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  buyerId Int  @map("buyer_id")

  recipientName String  @map("recipient_name")
  phone         String
  addressDetail String  @map("address_detail")
  city          String?
  province      String?
  postalCode    String? @map("postal_code")
  isDefault     Boolean @default(false) @map("is_default")

  orders Order[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([buyerId])
  @@map("addresses")
}

model Wallet {
  id Int @id @default(autoincrement())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @unique @map("user_id")

  balance Decimal @default(0) @db.Decimal(12, 2)

  transactions WalletTransaction[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("wallets")
}

model WalletTransaction {
  id Int @id @default(autoincrement())

  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  walletId Int    @map("wallet_id")

  type        WalletTransactionType
  amount      Decimal               @db.Decimal(12, 2)
  description String?
  referenceId Int?                  @map("reference_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([walletId])
  @@map("wallet_transactions")
}

// =========================
// CART
// =========================

model Cart {
  id Int @id @default(autoincrement())

  buyer   User @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  buyerId Int  @unique @map("buyer_id")

  // Nullable because cart can be empty.
  // Once buyer adds first product, cart is locked to that product's store.
  store   Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)
  storeId Int?   @map("store_id")

  items CartItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("carts")
}

model CartItem {
  id Int @id @default(autoincrement())

  cart   Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId Int  @map("cart_id")

  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId Int     @map("product_id")

  quantity Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([cartId, productId])
  @@map("cart_items")
}

// =========================
// DISCOUNTS
// =========================

model Voucher {
  id Int @id @default(autoincrement())

  name        String
  code        String  @unique
  description String?

  discountType      DiscountType @map("discount_type")
  discountValue     Decimal      @map("discount_value") @db.Decimal(12, 2)
  maxDiscountAmount Decimal?     @map("max_discount_amount") @db.Decimal(12, 2)
  minPurchaseAmount Decimal?     @map("min_purchase_amount") @db.Decimal(12, 2)

  remainingUsage Int      @map("remaining_usage")
  expiryDate     DateTime @map("expiry_date")
  isActive       Boolean  @default(true) @map("is_active")

  orders Order[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([code])
  @@map("vouchers")
}

model Promo {
  id Int @id @default(autoincrement())

  name        String
  code        String  @unique
  description String?

  discountType      DiscountType @map("discount_type")
  discountValue     Decimal      @map("discount_value") @db.Decimal(12, 2)
  maxDiscountAmount Decimal?     @map("max_discount_amount") @db.Decimal(12, 2)
  minPurchaseAmount Decimal?     @map("min_purchase_amount") @db.Decimal(12, 2)

  expiryDate DateTime @map("expiry_date")
  isActive   Boolean  @default(true) @map("is_active")

  orders Order[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([code])
  @@map("promos")
}

// =========================
// ORDER & CHECKOUT
// =========================

model Order {
  id          Int    @id @default(autoincrement())
  orderNumber String @unique @map("order_number")

  buyer   User @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  buyerId Int  @map("buyer_id")

  store   Store @relation(fields: [storeId], references: [id], onDelete: Restrict)
  storeId Int   @map("store_id")

  address   Address @relation(fields: [addressId], references: [id], onDelete: Restrict)
  addressId Int     @map("address_id")

  voucher   Voucher? @relation(fields: [voucherId], references: [id], onDelete: SetNull)
  voucherId Int?     @map("voucher_id")

  promo   Promo? @relation(fields: [promoId], references: [id], onDelete: SetNull)
  promoId Int?   @map("promo_id")

  // Shipping snapshot.
  // Address data is copied here during checkout so order history does not change
  // when buyer edits/deletes their address later.
  shippingRecipientName String @map("shipping_recipient_name")
  shippingPhone         String @map("shipping_phone")
  shippingAddress       String @map("shipping_address")

  deliveryMethod DeliveryMethod @map("delivery_method")

  subtotal       Decimal @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(12, 2)
  deliveryFee    Decimal @map("delivery_fee") @db.Decimal(12, 2)
  ppnAmount      Decimal @map("ppn_amount") @db.Decimal(12, 2)
  finalTotal     Decimal @map("final_total") @db.Decimal(12, 2)

  status OrderStatus @default(SEDANG_DIKEMAS)

  paidAt      DateTime? @map("paid_at")
  expiredAt   DateTime  @map("expired_at")
  completedAt DateTime? @map("completed_at")
  returnedAt  DateTime? @map("returned_at")

  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  deliveryJob   DeliveryJob?
  sellerIncome  SellerIncome?
  refund        Refund?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([buyerId])
  @@index([storeId])
  @@index([status])
  @@index([expiredAt])
  @@map("orders")
}

model OrderItem {
  id Int @id @default(autoincrement())

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId Int   @map("order_id")

  // Nullable because order history must survive even if the product is deleted later.
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productId Int?     @map("product_id")

  // Product snapshot at checkout time.
  productName  String  @map("product_name")
  productPrice Decimal @map("product_price") @db.Decimal(12, 2)
  quantity     Int
  subtotal     Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderStatusHistory {
  id Int @id @default(autoincrement())

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId Int   @map("order_id")

  status OrderStatus
  notes  String?

  changedByUser   User? @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)
  changedByUserId Int?  @map("changed_by_user_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@map("order_status_histories")
}

// =========================
// DELIVERY & DRIVER
// =========================

model DeliveryJob {
  id Int @id @default(autoincrement())

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId Int   @unique @map("order_id")

  driver   User? @relation(fields: [driverId], references: [id], onDelete: SetNull)
  driverId Int?  @map("driver_id")

  deliveryMethod DeliveryMethod @map("delivery_method")
  deliveryFee    Decimal        @map("delivery_fee") @db.Decimal(12, 2)
  earning        Decimal        @default(0) @db.Decimal(12, 2)

  status DeliveryJobStatus @default(AVAILABLE)

  takenAt     DateTime? @map("taken_at")
  completedAt DateTime? @map("completed_at")

  driverEarning DriverEarning?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([driverId])
  @@index([status])
  @@map("delivery_jobs")
}

model DriverEarning {
  id Int @id @default(autoincrement())

  driver   User @relation(fields: [driverId], references: [id], onDelete: Cascade)
  driverId Int  @map("driver_id")

  deliveryJob   DeliveryJob @relation(fields: [deliveryJobId], references: [id], onDelete: Cascade)
  deliveryJobId Int         @unique @map("delivery_job_id")

  amount Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([driverId])
  @@map("driver_earnings")
}

// =========================
// SELLER REPORT
// =========================

model SellerIncome {
  id Int @id @default(autoincrement())

  store   Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeId Int   @map("store_id")

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId Int   @unique @map("order_id")

  amount Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([storeId])
  @@map("seller_incomes")
}

// =========================
// REFUND / OVERDUE
// =========================

model Refund {
  id Int @id @default(autoincrement())

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId Int   @unique @map("order_id")

  buyer   User @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  buyerId Int  @map("buyer_id")

  amount Decimal      @db.Decimal(12, 2)
  reason String
  status RefundStatus @default(PENDING)

  processedAt DateTime? @map("processed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([buyerId])
  @@map("refunds")
}

// =========================
// SYSTEM TIME SIMULATION
// =========================

model SystemSetting {
  id Int @id @default(autoincrement())

  // Internal application time.
  // Checkout, voucher validation, promo validation, overdue checking,
  // and admin next-day simulation should use this value instead of directly using server time.
  currentDatetime DateTime @map("current_datetime")

  updatedByUser   User? @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)
  updatedByUserId Int?  @map("updated_by_user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}
